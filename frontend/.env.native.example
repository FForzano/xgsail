# Env for native (Capacitor) builds only — used by `npx cap sync` and
# scripts/deploy-ota.sh, never by `vite dev`/the browser build (see .env).
#
# There is no same-origin nginx proxy inside a WebView, so this MUST be a
# full, real backend origin — and specifically api.xgsail.com (the Cloudflare
# Tunnel route straight to `backend:8000`, see deploy/README.md), NOT
# xgsail.com/api (which goes through the frontend's nginx and its 10 MB
# client_max_body_size cap on /api/ — fine for the web SPA, a real problem
# for large session uploads from native).
VITE_API_BASE=https://api.xgsail.com/api

# Marks this as a native build: skips the marketing landing page (there's
# no one to market to on a device the user already installed the app on)
# and goes straight to /login, or /diario/activities if already authed —
# see config/platform.ts and pages/Landing.tsx.
VITE_APP_MODE=native

# This file is used for the GitHub Release sideload APK (android-release.yml),
# which has no in-app store donation system — so it keeps the in-app Buy Me a
# Coffee links (config/platform.ts, canShowSupportLinks). A future Play
# Store / App Store build must override this to VITE_APP_DISTRIBUTION=store
# in its own env before building, to hide them in favor of the store's own
# donation system (see the play-store-upload job in android-release.yml).
VITE_APP_DISTRIBUTION=sideload

# Copy to .env.native (gitignored) and fill in real values before building:
#   cp .env.native.example .env.native
#   set -a && source .env.native && set +a && npm run build && npx cap sync
