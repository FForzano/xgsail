# SailFrames environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.
#
# In production (AWS Lambda) these go on the function as Environment Variables
# (Lambda Console → Configuration → Environment variables) or in AWS Secrets
# Manager. The same env var names are read by the Lambda at runtime.

# --- Synoptic Data (Mesonet aggregator) ---
# Generate a TOKEN (not the API Key) from your Customer Console:
#   https://customer.synopticdata.com/  →  Credentials → Tokens → Create Token
# The TOKEN is what you put here. The API Key stays in the Synoptic console;
# never store the API Key on disk or in code.
SYNOPTIC_TOKEN=

# --- WeatherFlow / Tempest (optional, separate provider) ---
# Generate via the Tempest mobile app once an account is set up:
#   Settings → Data Authorizations → Personal Use Token
WEATHERFLOW_TOKEN=

# --- AWS profile (used by deploy.sh + flash-edge.sh helpers) ---
# Profile name in ~/.aws/credentials, not the access key itself.
AWS_PROFILE=sailframes

# --- Self-hosted stack (docker-compose.yml + MinIO) ---
# Only needed to run SailFrames without AWS. See deploy/README.md.
# MinIO root credentials (also used by the API as AWS_* creds).
MINIO_ROOT_USER=sailframes
MINIO_ROOT_PASSWORD=change-me-long-secret
# Bucket name — keep the prod name so firmware s3_bucket default still matches.
SAILFRAMES_BUCKET=sailframes-fleet-data-prod
SAILFRAMES_DATA_PREFIX=processed
AWS_DEFAULT_REGION=us-east-1
# Shared secret gating the MinIO -> /hooks/minio ingest webhook.
SAILFRAMES_HOOK_TOKEN=change-me-random-token

# --- Storage backend selection ---
# Blob storage for ALL files (large sensor data + small JSON).
#   s3    : AWS S3 (default; uses the standard AWS creds/region)
#   minio : self-hosted MinIO (requires SAILFRAMES_S3_ENDPOINT below)
#   local : local filesystem under SAILFRAMES_LOCAL_DATA
# If unset, the backend is derived from the legacy vars: SAILFRAMES_LOCAL_DATA
# set -> local; SAILFRAMES_S3_ENDPOINT set -> minio; else s3. The compose stack
# sets SAILFRAMES_S3_ENDPOINT, so it runs as `minio` out of the box.
# SAILFRAMES_STORAGE_BACKEND=minio
# SAILFRAMES_S3_ENDPOINT=http://minio:9000
# SAILFRAMES_LOCAL_DATA=/data

# --- Metadata backend (small structured data only) ---
#   object   : JSON in the blob store (preserves pre-postgres behaviour)
#   postgres : SQLAlchemy + Postgres (race metadata, sessions, users + RBAC)
# Postgres is FastAPI/self-hosted only; cloud Lambdas always use object storage.
# The self-hosted docker-compose.yml runs Postgres by default and hardcodes
# SAILFRAMES_METADATA_BACKEND=postgres + POSTGRES_HOST/PORT on the api service
# (pointing at the `postgres` service) — those are NOT read from .env. Only
# the credentials below are; web/api/db/__init__.py builds the SQLAlchemy URL
# from the discrete POSTGRES_USER/PASSWORD/DB vars (no concatenated
# DATABASE_URL with the password embedded in one plaintext token).
POSTGRES_USER=sailframes
POSTGRES_PASSWORD=change-me-long-secret
POSTGRES_DB=sailframes

# --- RBAC bootstrap (postgres backend only) ---
# Optional first superadmin, seeded on startup. Identity for permission checks
# is read from a trusted reverse-proxy header (default X-Auth-Email) until the
# login/token flow ships.
SAILFRAMES_SUPERADMIN_EMAIL=
SAILFRAMES_SUPERADMIN_PASSWORD=
# SAILFRAMES_AUTH_EMAIL_HEADER=X-Auth-Email
